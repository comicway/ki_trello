rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getBoardData(boardId) {
      return get(/databases/$(database)/documents/boards/$(boardId)).data;
    }

    function boardOwnerIds(board) {
      return board.get('ownerIds', board.ownerId != null ? [board.ownerId] : []);
    }

    function isBoardOwner(board) {
      return isSignedIn() && request.auth.uid in boardOwnerIds(board);
    }

    function isBoardOwnerById(boardId) {
      return isBoardOwner(getBoardData(boardId));
    }

    function isBoardMemberEmail(board) {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in board.get('memberEmails', []);
    }

    function canAccessBoard(board) {
      return isBoardOwner(board) || isBoardMemberEmail(board);
    }

    function canAccessBoardById(boardId) {
      return canAccessBoard(getBoardData(boardId));
    }

    function membersUnchanged() {
      return request.resource.data.members == resource.data.members;
    }

    function memberEmailsUnchanged() {
      return request.resource.data.memberEmails == resource.data.memberEmails;
    }

    function ownerIdsUnchanged() {
      return request.resource.data.get('ownerIds', []) == resource.data.get('ownerIds', []);
    }

    function ownerIdLegacyUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    function rolesUnchanged() {
      return ownerIdsUnchanged() && ownerIdLegacyUnchanged();
    }

    function boardMetaOnlyUpdate() {
      return membersUnchanged()
        && memberEmailsUnchanged()
        && rolesUnchanged();
    }

    function isMemberSelfClaim() {
      return isBoardMemberEmail(resource.data)
        && memberEmailsUnchanged()
        && rolesUnchanged()
        && request.resource.data.members.size() == resource.data.members.size();
    }

    match /boards/{boardId} {

      allow get: if canAccessBoard(resource.data);

      allow list: if isSignedIn() && (
        request.auth.uid in resource.data.get('ownerIds', [])
        || resource.data.ownerId == request.auth.uid
        || request.auth.token.email in resource.data.get('memberEmails', [])
      );

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.ownerIds
        && request.resource.data.ownerIds.size() > 0
        && request.auth.token.email in request.resource.data.memberEmails
        && request.resource.data.memberEmails.size() > 0
        && request.resource.data.members.size() > 0;

      allow update: if canAccessBoard(resource.data) && (
        isBoardOwner(resource.data)
        || boardMetaOnlyUpdate()
        || isMemberSelfClaim()
      );

      allow delete: if isBoardOwner(resource.data);

      match /lists/{listId} {
        allow read, write: if canAccessBoardById(boardId);

        match /tareas/{tareaId} {
          allow read, create, update, delete: if canAccessBoardById(boardId);

          match /comments/{commentId} {
            allow read: if canAccessBoardById(boardId);
            allow create: if canAccessBoardById(boardId)
              && request.resource.data.authorEmail == request.auth.token.email;
            allow update, delete: if canAccessBoardById(boardId)
              && resource.data.authorEmail == request.auth.token.email;
          }

          match /subtaskComments/{subtaskId}/comments/{commentId} {
            allow read: if canAccessBoardById(boardId);
            allow create: if canAccessBoardById(boardId)
              && request.resource.data.authorEmail == request.auth.token.email;
            allow update, delete: if canAccessBoardById(boardId)
              && resource.data.authorEmail == request.auth.token.email;
          }
        }
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;

      match /boardRefs/{boardRefId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
